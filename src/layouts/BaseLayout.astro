---
import "@/styles/global.css";
import SiteNav from "@/components/SiteNav.astro";
import CommandMenu from "@/components/CommandMenu.astro";
import { getAllDocs, getActiveNavDomain } from "@/lib/docs";
import type { DocEntry } from "@/lib/docs";

interface Props {
  title: string;
  activeDomain?: string | null;
  docs?: DocEntry[];
}

const { title, activeDomain: activeDomainProp } = Astro.props;
const docs = Astro.props.docs ?? (await getAllDocs());
const activeDomain =
  activeDomainProp ?? getActiveNavDomain(Astro.url.pathname);
const isLanding =
  Astro.url.pathname !== "/" &&
  Astro.url.pathname.split("/").filter(Boolean).length >= 1;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — code-design-guide</title>
  </head>
  <body>
    <div class="page">
      <SiteNav activeDomain={isLanding ? activeDomain : null} />
      <slot />
    </div>
    <CommandMenu docs={docs} />
  </body>
</html>
