---
import "@/styles/global.css";
import LenisSmoothScroll from "@/components/LenisSmoothScroll.astro";
import SiteNav from "@/components/SiteNav.astro";
import CommandMenu from "@/components/CommandMenu.astro";
import { getAllDocs } from "@/lib/docs";
import type { DocEntry } from "@/lib/docs";

interface Props {
  title: string;
  docs?: DocEntry[];
}

const { title } = Astro.props;
const docs = Astro.props.docs ?? (await getAllDocs());
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — code-design-guide</title>
  </head>
  <body>
    <div class="page">
      <SiteNav />
      <slot />
    </div>
    <CommandMenu docs={docs} />
    <LenisSmoothScroll />
  </body>
</html>
