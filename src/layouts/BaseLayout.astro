---
import "@/styles/global.css";
import SiteNav from "@/components/SiteNav.astro";
import CommandMenu from "@/components/CommandMenu.astro";
import BarbaTransitions from "@/components/BarbaTransitions.astro";
import { getAllDocs } from "@/lib/docs";
import { getNamespace } from "@/lib/barba/getNamespace";
import type { DocEntry } from "@/lib/docs";

interface Props {
  title: string;
  docs?: DocEntry[];
  barbaNamespace?: string;
  pageTheme?: "light" | "dark";
}

const { title, pageTheme = "light" } = Astro.props;
const docs = Astro.props.docs ?? (await getAllDocs());
const barbaNamespace =
  Astro.props.barbaNamespace ?? getNamespace(Astro.url.pathname);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — code-design-guide</title>
  </head>
  <body data-barba="wrapper">
    <div data-transition-wrap class="transition" aria-hidden="true">
      <template data-transition-shutter-template>
        <div data-transition-shutter class="transition__shutter"></div>
      </template>
      <template data-transition-pixel-template>
        <div data-transition-col class="transition__col">
          <div data-transition-pixel class="transition__pixel"></div>
        </div>
      </template>
      <template data-transition-sliding-column-template>
        <div data-transition-column class="transition__column"></div>
      </template>
      <div data-transition-panel class="transition__panel"></div>
    </div>

    <SiteNav />

    <main
      data-barba="container"
      data-barba-namespace={barbaNamespace}
      data-page-theme={pageTheme}
      class="barba-container"
    >
      <slot />
    </main>

    <CommandMenu docs={docs} />
    <BarbaTransitions />
  </body>
</html>
