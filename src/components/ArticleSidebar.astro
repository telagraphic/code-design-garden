---
import type { DocEntry } from "@/lib/docs";
import {
  getChapterGroups,
  getPagePath,
  getSlug,
  getSectionTitle,
} from "@/lib/docs";

interface Props {
  entry: DocEntry;
  sectionDocs: DocEntry[];
  headings: { depth: number; slug: string; text: string }[];
}

const { entry, sectionDocs, headings } = Astro.props;
const { domain, section, chapter, title } = entry.data;
const chapterGroups = getChapterGroups(sectionDocs, domain, section);
const currentChapter = chapterGroups.find((g) => g.slug === chapter);
const otherChapters = chapterGroups.filter((g) => g.slug !== chapter);
const currentSlug = getSlug(entry);

const markdownH1Slug = headings.find((h) => h.depth === 1)?.slug;
const tocHeadings = headings.filter(
  (h) => h.depth >= 2 && h.depth <= 4 && h.slug !== markdownH1Slug,
);
---

<aside
  class="sidebar sidebar--content"
  aria-label="Page navigation"
  data-lenis-prevent
>
  <a href={`/${domain}/${section}`} class="sidebar__back">
    ← {getSectionTitle(sectionDocs, domain, section)}
  </a>

  <>
    <p class="sidebar__label">On this page</p>
    <nav class="sidebar__nav sidebar__nav--toc" aria-label="On this page">
      <a
        href="#introduction"
        class="sidebar__link sidebar__link--depth-1"
        data-toc-id="introduction"
      >
        {title}
      </a>
      {
        tocHeadings.map((h) => (
          <a
            href={`#${h.slug}`}
            class:list={[
              "sidebar__link",
              `sidebar__link--depth-${h.depth}`,
            ]}
            data-toc-id={h.slug}
          >
            {h.text}
          </a>
        ))
      }
    </nav>
    <div class="sidebar__divider" role="presentation" />
  </>

  {
    currentChapter && currentChapter.pages.length > 0 && (
      <>
        <p class="sidebar__label">{currentChapter.label}</p>
        <nav class="sidebar__nav" aria-label={currentChapter.label}>
          {
            currentChapter.pages.map((page) => (
              <a
                href={getPagePath(page)}
                class:list={[
                  "sidebar__link",
                  getSlug(page) === currentSlug && "sidebar__link--active",
                ]}
                aria-current={getSlug(page) === currentSlug ? "page" : undefined}
              >
                {page.data.title}
              </a>
            ))
          }
        </nav>
        <div class="sidebar__divider" role="presentation" />
      </>
    )
  }

  {
    otherChapters.length > 0 && (
      <>
        <p class="sidebar__label sidebar__label--faint">
          {getSectionTitle(sectionDocs, domain, section)}
        </p>
        <nav
          class="sidebar__nav"
          aria-label={getSectionTitle(sectionDocs, domain, section)}
        >
          {
            otherChapters.map((ch) => (
              <a
                href={
                  ch.pages[0]
                    ? getPagePath(ch.pages[0])
                    : `/${domain}/${section}#${ch.slug}`
                }
                class="sidebar__link sidebar__link--faint"
              >
                {ch.label}
              </a>
            ))
          }
        </nav>
      </>
    )
  }
</aside>
