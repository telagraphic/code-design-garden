---
/** Highlights "On this page" sidebar links based on scroll position. */
---

<script>
  const HEADING_SELECTOR =
    "#introduction, .prose h2[id], .prose h3[id], .prose h4[id]";

  let scrollCleanup: (() => void) | null = null;

  function getActivationOffset(): number {
    const nav = document.querySelector(".site-nav");
    const navHeight = nav?.getBoundingClientRect().height ?? 0;
    return navHeight + 24;
  }

  function setActiveTocLink(links: HTMLAnchorElement[], activeId: string | null) {
    for (const link of links) {
      const isActive = link.dataset.tocId === activeId;
      link.classList.toggle("sidebar__link--in-view", isActive);
      if (isActive) {
        link.setAttribute("aria-current", "location");
      } else {
        link.removeAttribute("aria-current");
      }
    }
  }

  /** Last heading at or above the activation line — stays active until the next crosses it. */
  function pickActiveSection(sections: HTMLElement[]): string | null {
    if (!sections.length) return null;

    const offset = getActivationOffset();
    let activeId = sections[0].id;

    for (const section of sections) {
      if (section.getBoundingClientRect().top <= offset) {
        activeId = section.id;
      } else {
        break;
      }
    }

    return activeId;
  }

  function initSidebarScrollSpy(root: ParentNode = document) {
    const nav = root.querySelector(".sidebar__nav--toc");
    if (!nav) return;

    scrollCleanup?.();
    nav.removeAttribute("data-scroll-spy-init");

    const links = [
      ...nav.querySelectorAll<HTMLAnchorElement>("[data-toc-id]"),
    ];
    if (!links.length) return;

    const sections = [
      ...root.querySelectorAll<HTMLElement>(HEADING_SELECTOR),
    ].filter((el) => el.id);

    if (!sections.length) return;

    nav.setAttribute("data-scroll-spy-init", "true");

    const update = () => {
      setActiveTocLink(links, pickActiveSection(sections));
    };

    let ticking = false;
    const onScrollOrResize = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        update();
        ticking = false;
      });
    };

    window.addEventListener("scroll", onScrollOrResize, { passive: true });
    window.addEventListener("resize", onScrollOrResize, { passive: true });

    scrollCleanup = () => {
      window.removeEventListener("scroll", onScrollOrResize);
      window.removeEventListener("resize", onScrollOrResize);
    };

    for (const link of links) {
      link.addEventListener("click", () => {
        const id = link.dataset.tocId;
        if (id) setActiveTocLink(links, id);
      });
    }

    update();
  }

  function setup(root: ParentNode = document) {
    initSidebarScrollSpy(root);
  }

  setup();
  document.addEventListener("astro:page-load", () => setup());
</script>
