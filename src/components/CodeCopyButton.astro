---
import {
  CHECK_ICON_PATH,
  COPY_ICON_PATHS,
  COPY_TOOLTIP,
  ICON_STROKE_WIDTH,
} from "@/lib/code-snippet.mjs";

interface Props {
  class?: string;
  codeTabsCopy?: boolean;
}

const { class: className = "", codeTabsCopy = false } = Astro.props;
---

<button
  type="button"
  class:list={["code-snippet__copy", className]}
  aria-label={COPY_TOOLTIP}
  data-tooltip={COPY_TOOLTIP}
  {...(codeTabsCopy ? { "data-code-tabs-copy": "" } : {})}
>
  <span class="code-snippet__icon-stack">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      aria-hidden="true"
      class="code-snippet__icon code-snippet__icon--copy"
    >
      {
        COPY_ICON_PATHS.map((spec) => (
          <path
            d={spec.d}
            stroke="currentColor"
            stroke-width={ICON_STROKE_WIDTH}
            stroke-linecap="round"
            stroke-linejoin="round"
            fill="none"
          />
        ))
      }
    </svg>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      aria-hidden="true"
      class="code-snippet__icon code-snippet__icon--check"
    >
      <path
        d={CHECK_ICON_PATH.d}
        stroke="currentColor"
        stroke-width={ICON_STROKE_WIDTH}
        stroke-linecap="round"
        stroke-linejoin="round"
        fill="none"
      />
    </svg>
  </span>
</button>
