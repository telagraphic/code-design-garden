---
import type { AnimationEntry } from "@/lib/animations";

interface Props {
  entry: AnimationEntry;
  headings: { depth: number; slug: string; text: string }[];
}

const { entry, headings } = Astro.props;
const galleryHref = "/design/library";

const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 4);
---

<aside
  class="sidebar sidebar--content"
  aria-label="Animation navigation"
  data-lenis-prevent
>
  <a href={galleryHref} class="sidebar__back">← Collection</a>

  {
    tocHeadings.length > 0 && (
      <>
        <p class="sidebar__label">On this page</p>
        <nav class="sidebar__nav sidebar__nav--toc" aria-label="On this page">
          <a
            href="#introduction"
            class="sidebar__link sidebar__link--depth-1"
            data-toc-id="introduction"
          >
            {entry.data.title}
          </a>
          {
            tocHeadings.map((h) => (
              <a
                href={`#${h.slug}`}
                class:list={[
                  "sidebar__link",
                  `sidebar__link--depth-${h.depth}`,
                ]}
                data-toc-id={h.slug}
              >
                {h.text}
              </a>
            ))
          }
        </nav>
      </>
    )
  }
</aside>
